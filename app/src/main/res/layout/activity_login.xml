<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/g1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Logo -->
            <TextView
                android:id="@+id/tv_negocio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 TiendaNaturistaMX"
                android:textColor="@color/g1"
                android:textSize="22sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona tienda y cajero"
                android:textColor="@color/txt3"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"/>

            <!-- Tienda -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIENDA"
                android:textColor="@color/txt2"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/ll_tiendas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="18dp"/>

            <!-- Cajero -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAJERO"
                android:textColor="@color/txt2"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/ll_cajeros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="18dp"/>

            <!-- PIN -->
            <LinearLayout
                android:id="@+id/layout_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PIN"
                    android:textColor="@color/txt2"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/et_pin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberPassword"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:letterSpacing="0.3"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="14dp"
                    android:hint="••••"/>

                <TextView
                    android:id="@+id/tv_pin_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ PIN incorrecto"
                    android:textColor="@color/red_txt"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Fondo -->
            <LinearLayout
                android:id="@+id/layout_fondo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fondo inicial *"
                    android:textColor="@color/txt2"
                    android:textSize="13sp"
                    android:layout_marginEnd="10dp"/>

                <EditText
                    android:id="@+id/et_fondo"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:textSize="16sp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="12dp"
                    android:hint="0.00"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MXN"
                    android:textColor="@color/txt3"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_fondo_warn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Captura el fondo inicial antes de iniciar"
                android:textColor="@color/red_txt"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="14dp"/>

            <!-- Botón entrar -->
            <Button
                android:id="@+id/btn_entrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Iniciar turno →"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/g2"
                app:cornerRadius="12dp"
                android:enabled="false"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
