<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottomsheet"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_handle"/>

    <TextView
        android:id="@+id/tv_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💳 Cobrar"
        android:textSize="19sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/g1"
        android:layout_marginBottom="18dp"/>

    <!-- Formas de pago -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <Button
            android:id="@+id/btn_efectivo"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="💵 Efectivo"
            android:textSize="13sp"
            android:backgroundTint="@color/g7"
            android:textColor="@color/g1"
            app:cornerRadius="14dp"

        <Button
            android:id="@+id/btn_tarjeta"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="5dp"
            android:text="💳 Tarjeta"
            android:textSize="13sp"
            android:backgroundTint="@color/border"
            android:textColor="@color/txt2"
            app:cornerRadius="14dp"/>

        <Button
            android:id="@+id/btn_transfer"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="📲 Transfer."
            android:textSize="13sp"
            android:backgroundTint="@color/border"
            android:textColor="@color/txt2"
            app:cornerRadius="14dp"/>
    </LinearLayout>

    <!-- Recibido -->
    <LinearLayout
        android:id="@+id/layout_recibido"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recibido"
            android:textColor="@color/txt2"
            android:textSize="14sp"
            android:layout_marginEnd="10dp"/>

        <EditText
            android:id="@+id/et_recibido"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:inputType="numberDecimal"
            android:textSize="20sp"
            android:textAlignment="textEnd"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="13dp"
            android:hint="0.00"/>
    </LinearLayout>

    <!-- Cambio -->
    <LinearLayout
        android:id="@+id/layout_cambio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cambio"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="18dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cambio"
            android:textColor="@color/txt2"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/tv_cambio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/g1"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_confirmar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="✓ Confirmar venta"
        android:textSize="17sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/g2"
        app:cornerRadius="14dp"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
